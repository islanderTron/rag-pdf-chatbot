# ─────────────────────────────────────────────
# RAG PDF Chatbot — Provider Configuration
# ─────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Only the block matching your chosen LLM_PROVIDER is required.

# Choose one: ollama | openai | anthropic
LLM_PROVIDER=ollama

# ── Ollama (free, runs locally) ──────────────
OLLAMA_MODEL=llama3.2:1b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434

# ── OpenAI / ChatGPT ─────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic / Claude ───────────────────────
# Note: Anthropic has no embeddings API.
# When using anthropic, set OPENAI_API_KEY too — it's used only for embeddings.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
